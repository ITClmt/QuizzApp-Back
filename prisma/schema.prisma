// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  email         String         @unique
  password      String
  avatarSlug    String         @default("default")
  role          Role           @default(USER)
  lang          String         @default("en")
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  scores           Score[]
  sentRequests     Friendship[]  @relation("requester")
  receivedRequests Friendship[]  @relation("receiver")
  gamePlayers      GamePlayer[]
  soloSessions     SoloSession[]
}

model Question {
  id           String   @id @default(uuid())
  sourceId     String   @unique
  questionEn   String
  questionFr   String?
  answersEn    Json
  answersFr    Json?
  correctIndex Int
  category     String
  difficulty   String
  createdAt    DateTime @default(now())

  gameQuestions GameQuestion[]
  soloAnswers   SoloAnswer[]
}

model Score {
  id         String     @id @default(uuid())
  value      Int
  difficulty Difficulty
  createdAt  DateTime   @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friendship {
  id        String           @id @default(uuid())
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())

  requesterId String
  requester   User   @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   User   @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model Game {
  id        String     @id @default(uuid())
  code      String     @unique
  status    GameStatus @default(WAITING)
  createdAt DateTime   @default(now())

  players       GamePlayer[]
  gameQuestions GameQuestion[]
}

model GamePlayer {
  id     String  @id @default(uuid())
  score  Int     @default(0)
  isHost Boolean @default(false)

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
}

model GameQuestion {
  id    String @id @default(uuid())
  order Int

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([gameId, order])
}

model SoloSession {
  id         String            @id @default(uuid())
  status     SoloSessionStatus @default(IN_PROGRESS)
  difficulty Difficulty?
  category   String?
  lang       String            @default("en")
  expiresAt  DateTime
  createdAt  DateTime          @default(now())

  userId  String
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers SoloAnswer[]
}

model SoloAnswer {
  id          String   @id @default(uuid())
  answerIndex Int
  isCorrect   Boolean
  createdAt   DateTime @default(now())

  sessionId   String
  soloSession SoloSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum GameStatus {
  WAITING
  PLAYING
  FINISHED
}

enum SoloSessionStatus {
  IN_PROGRESS
  FINISHED
  EXPIRED
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  easy
  medium
  hard
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
